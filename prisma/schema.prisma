generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  learner
  admin
}

enum ResourceType {
  video
  article
  documentation
  interactive
}

enum QuizType {
  diagnostic
  practice
  spaced_repetition
  code_challenge
}

enum UserMood {
  chill
  excited
  focused
  tired
  goofy
  sleepy
  hungry
  grumpy
  anxious
  confident
}

enum BadgeCategory {
  mastery
  streak
  quiz
  social
  special
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(learner)
  bio       String   @default("")
  tierId           String?
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  avatarUrl          String?
  avatarCreatedAt    DateTime?
  avatarShirtColor   String   @default("#3D5A45")
  avatarPantsColor   String   @default("#2D4635")
  avatarHairColor    String   @default("#4A3728")
  avatarSkinColor    String   @default("#E8C4A0")
  mood               UserMood @default(chill)
  currentTrackId     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tier              TierDefinition?    @relation(fields: [tierId], references: [id])
  currentTrack      Track?             @relation(fields: [currentTrackId], references: [id])
  quizAttempts      QuizAttempt[]
  masteryScores     MasteryScore[]
  leaderboardSnaps  LeaderboardSnapshot[]
  spacedRepetitions SpacedRepetition[]
  badges            UserBadge[]
  followers         Follow[]          @relation("following")
  following         Follow[]          @relation("follower")
  challengeSubmissions ChallengeSubmission[]
  dailyChallenges       UserDailyChallenge[]
  seasonScores          UserSeasonScore[]
  battlesInitiated     Battle[]   @relation("challenger")
  battlesReceived      Battle[]   @relation("opponent")
}

model Track {
  id          String @id @default(cuid())
  name        String @unique
  description String
  longDescription String @default("")
  icon        String @default("📚")
  color       String @default("#6366f1")
  difficulty  String @default("Beginner")
  popularity  Int    @default(0)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())

  subDomains  SubDomain[]
  users       User[]
  quizAttempts QuizAttempt[]
  battles     Battle[]
}

model SubDomain {
  id          String @id @default(cuid())
  name        String
  description String
  trackId     String
  order       Int    @default(0)
  createdAt   DateTime @default(now())

  track     Track      @relation(fields: [trackId], references: [id], onDelete: Cascade)
  concepts  Concept[]
}

model Concept {
  id          String @id @default(cuid())
  name        String
  description String
  subDomainId String
  order       Int    @default(0)
  createdAt   DateTime @default(now())

  subDomain         SubDomain           @relation(fields: [subDomainId], references: [id], onDelete: Cascade)
  questions         Question[]
  resources         Resource[]
  masteryScores     MasteryScore[]
  spacedRepetitions SpacedRepetition[]
  codeChallenges    CodeChallenge[]
}

model Question {
  id               String  @id @default(cuid())
  text             String
  codeSnippet      String  @default("")
  conceptId        String
  difficultyWeight Float   @default(1.0)
  explanation      String
  isActive         Boolean @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  concept        Concept       @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  choices        Choice[]
  answerLogs     AnswerLog[]
}

model Choice {
  id         String @id @default(cuid())
  text       String
  isCorrect  Boolean @default(false)
  questionId String

  question   Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answerLogs AnswerLog[]
}

model Resource {
  id          String       @id @default(cuid())
  title       String
  description String
  url         String
  type        ResourceType @default(video)
  conceptId   String
  createdAt   DateTime     @default(now())

  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  trackId     String?
  type        QuizType @default(practice)
  score       Float?
  totalWeight Float?
  completed   Boolean  @default(false)
  startedAt   DateTime @default(now())
  completedAt DateTime?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  track      Track?      @relation(fields: [trackId], references: [id])
  answerLogs AnswerLog[]
}

model AnswerLog {
  id            String   @id @default(cuid())
  quizAttemptId String
  questionId    String
  choiceId      String
  isCorrect     Boolean
  timeSpent     Int?
  createdAt     DateTime @default(now())

  quizAttempt QuizAttempt @relation(fields: [quizAttemptId], references: [id], onDelete: Cascade)
  question    Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  choice      Choice      @relation(fields: [choiceId], references: [id], onDelete: Cascade)
}

model MasteryScore {
  id           String   @id @default(cuid())
  userId       String
  conceptId    String
  score        Float    @default(0.0)
  attempts     Int      @default(0)
  correctCount Int      @default(0)
  lastTestedAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@unique([userId, conceptId])
}

model TierDefinition {
  id        String @id @default(cuid())
  name      String @unique
  minScore  Float
  color     String @default("#6366f1")
  icon      String @default("⭐")
  createdAt DateTime @default(now())

  users  User[]
}

model LeaderboardSnapshot {
  id        String   @id @default(cuid())
  userId    String
  score     Float
  rank      Int
  period    String   @default("weekly")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SpacedRepetition {
  id           String   @id @default(cuid())
  userId       String
  conceptId    String
  interval     Int      @default(1)
  easeFactor   Float    @default(2.5)
  nextReviewAt DateTime @default(now())
  createdAt    DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@unique([userId, conceptId])
}

model Badge {
  id          String         @id @default(cuid())
  name        String         @unique
  description String
  icon        String         @default("🏆")
  color       String         @default("#F59E0B")
  category    BadgeCategory  @default(mastery)
  criteria    String         @default("")
  maxProgress Int            @default(1)
  createdAt   DateTime       @default(now())

  users UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  progress  Int      @default(0)
  earned    Boolean  @default(false)
  earnedAt  DateTime?
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model CodeChallenge {
  id              String   @id @default(cuid())
  title           String
  description     String
  difficulty      String   @default("easy")
  templateCode    String   @default("")
  solutionCode    String   @default("")
  testCases       String   @default("[]")
  language        String   @default("python")
  conceptId       String
  order           Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  concept       Concept                @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  submissions   ChallengeSubmission[]
}

model ChallengeSubmission {
  id              String   @id @default(cuid())
  userId          String
  challengeId     String
  code            String
  passed          Boolean  @default(false)
  score           Float?   @default(0)
  executionTimeMs Int?
  createdAt       DateTime @default(now())

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge CodeChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
}

model DailyChallenge {
  id          String   @id @default(cuid())
  date        DateTime @unique // date-only (normalized to midnight)
  title       String
  description String
  type        String   @default("quiz") // quiz, perfect_score, streak, concepts
  target      Int      @default(5) // e.g., answer 5 questions
  reward      Int      @default(50) // bonus XP or points
  icon        String   @default("🎯")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  userProgress UserDailyChallenge[]
}

model UserDailyChallenge {
  id           String   @id @default(cuid())
  userId       String
  challengeId  String
  progress     Int      @default(0)
  completed    Boolean  @default(false)
  claimed      Boolean  @default(false)
  completedAt  DateTime?
  claimedAt    DateTime?
  createdAt    DateTime @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge DailyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
}

model LeaderboardSeason {
  id          String   @id @default(cuid())
  name        String   @unique
  period      String   @default("weekly") // weekly, monthly
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  isFinished  Boolean  @default(false)
  createdAt   DateTime @default(now())

  userScores  UserSeasonScore[]
}

model Battle {
  id              String   @id @default(cuid())
  challengerId    String
  opponentId      String
  trackId         String
  status          String   @default("pending") // pending, accepted, completed, declined
  challengerScore Float?
  opponentScore   Float?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())

  challenger   User  @relation("challenger", fields: [challengerId], references: [id], onDelete: Cascade)
  opponent     User  @relation("opponent", fields: [opponentId], references: [id], onDelete: Cascade)
  track        Track @relation(fields: [trackId], references: [id])

  @@index([challengerId])
  @@index([opponentId])
}

model UserSeasonScore {
  id        String   @id @default(cuid())
  userId    String
  seasonId  String
  score     Float    @default(0)
  rank      Int?
  quizzes   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  season  LeaderboardSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
}
